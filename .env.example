# ╔══════════════════════════════════════════════════════════════════════╗
# ║  MOLTY ROYALE AI AGENT — RAILWAY VARIABLES                         ║
# ║  Copy these to Railway Dashboard → Variables tab                   ║
# ╚══════════════════════════════════════════════════════════════════════╝

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# WAJIB DIISI (kamu isi manual di Railway Variables)
# NOTE: Untuk multi-agent, jangan isi AGENT_NAME/API_KEY/AGENT_WALLET_ADDRESS/AGENT_PRIVATE_KEY global.
# Gunakan hanya variabel PEAXELX_* untuk setiap profile.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ROOM_MODE=free                 # free = selalu free room (default)
                               # auto = paid kalau ready, fallback free
                               # paid = hanya paid room
LOG_LEVEL=INFO                 # DEBUG / INFO / WARNING

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# FIRST-RUN INTAKE (setup.md pertanyaan 1-9, jawaban via env var)
# Semua default = true/auto, jadi zero-config deploy langsung jalan
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
ADVANCED_MODE=true             # Q1-3: auto-generate Owner EOA + Agent wallet
AUTO_WHITELIST=true            # Q4: auto-check + auto-approve whitelist
AUTO_SC_WALLET=true            # Q6: auto-create MoltyRoyale SC Wallet
ENABLE_MEMORY=true             # Q7: cross-game learning (molty-royale-context.json)
ENABLE_AGENT_TOKEN=false       # Q8: agent token registration (skip dulu)
AUTO_IDENTITY=true             # Q9: auto-register ERC-8004 identity

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# RAILWAY AUTO-SYNC (agar credentials persist walau container restart)
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
RAILWAY_API_TOKEN=             # Buat di: https://railway.com/account/tokens

# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# AUTO-GENERATED (JANGAN DIISI — bot akan mengisi otomatis)
# Setelah first-run, bot auto-save ke Railway Variables
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
OWNER_EOA=                     # Auto: generated Owner EOA address
OWNER_PRIVATE_KEY=             # Auto: generated Owner private key

# NOTE: Jika menggunakan AGENT_PROFILES untuk multi-agent,
# jangan isi global single-agent vars seperti AGENT_NAME, API_KEY,
# AGENT_WALLET_ADDRESS, AGENT_PRIVATE_KEY. Gunakan variabel
# PEAXELX_* yang sesuai untuk setiap profile.
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
# MULTI-AGENT SUPPORT
# Jika kamu ingin jalankan >1 agent sekaligus, isi section ini
# ━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━
AGENT_PROFILES=peaxel1,peaxel2,peaxel3,peaxel4,peaxel5

PEAXEL1_AGENT_NAME=peaxel1
PEAXEL1_OWNER_EOA=0x...       # sama dengan OWNER_EOA jika reward mau ke wallet kamu
PEAXEL1_API_KEY=
PEAXEL1_AGENT_PRIVATE_KEY=
PEAXEL1_AGENT_WALLET_ADDRESS=

PEAXEL2_AGENT_NAME=peaxel2
PEAXEL2_OWNER_EOA=0x...
PEAXEL2_API_KEY=
PEAXEL2_AGENT_PRIVATE_KEY=
PEAXEL2_AGENT_WALLET_ADDRESS=

PEAXEL3_AGENT_NAME=peaxel3
PEAXEL3_OWNER_EOA=0x...
PEAXEL3_API_KEY=
PEAXEL3_AGENT_PRIVATE_KEY=
PEAXEL3_AGENT_WALLET_ADDRESS=

PEAXEL4_AGENT_NAME=peaxel4
PEAXEL4_OWNER_EOA=0x...
PEAXEL4_API_KEY=
PEAXEL4_AGENT_PRIVATE_KEY=
PEAXEL4_AGENT_WALLET_ADDRESS=

PEAXEL5_AGENT_NAME=peaxel5
PEAXEL5_OWNER_EOA=0x...
PEAXEL5_API_KEY=
PEAXEL5_AGENT_PRIVATE_KEY=
PEAXEL5_AGENT_WALLET_ADDRESS=
